{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Debug (EXE)",
      "type": "shell",
      "command": "make exe-debug",
      "group": "build"
    },
    {
      "label": "Build Release (EXE)",
      "type": "shell",
      "command": "make -Bj exe-release",
      "group": "build"
    },
    {
      "label": "Build Release (DLL)",
      "type": "shell",
      "command": "make -Bj dll-release",
      "group": "build"
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "make clean",
      "group": "build"
    },
    {
      "label": "Run Windbg (EXE)",
      "type": "shell",
      "command": "make exe-windbg",
      "group": "test",
      "dependsOn": [
        "Build Debug (EXE)"
      ]
    }
  ]
}
